{
  "doctype": "DocType",
  "name": "AlphaX POS Loyalty Wallet",
  "module": "AlphaX POS Suite",
  "autoname": "format:LW-{customer}-{program}",
  "engine": "InnoDB",
  "fields": [
    {
      "fieldname": "customer",
      "label": "Customer",
      "fieldtype": "Link",
      "options": "Customer",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "program",
      "label": "Loyalty Program",
      "fieldtype": "Link",
      "options": "AlphaX POS Loyalty Program",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "card_number",
      "label": "Card / QR Code",
      "fieldtype": "Data",
      "unique": 1,
      "in_list_view": 1,
      "description": "Optional barcode / QR / card number for fast lookup at the till."
    },
    {
      "fieldname": "current_balance",
      "label": "Current Points Balance",
      "fieldtype": "Float",
      "default": 0,
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "lifetime_earned",
      "label": "Lifetime Earned",
      "fieldtype": "Float",
      "default": 0,
      "read_only": 1
    },
    {
      "fieldname": "lifetime_redeemed",
      "label": "Lifetime Redeemed",
      "fieldtype": "Float",
      "default": 0,
      "read_only": 1
    },
    {
      "fieldname": "current_tier",
      "label": "Current Tier",
      "fieldtype": "Data",
      "read_only": 1
    },
    {
      "fieldname": "enrolled_on",
      "label": "Enrolled On",
      "fieldtype": "Datetime",
      "read_only": 1
    },
    {
      "fieldname": "last_activity_on",
      "label": "Last Activity",
      "fieldtype": "Datetime",
      "read_only": 1
    }
  ],
  "permissions": [
    {"role": "AlphaX POS Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "AlphaX POS Supervisor", "read": 1, "write": 1, "create": 1},
    {"role": "AlphaX POS Cashier", "read": 1, "write": 1, "create": 1},
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1}
  ],
  "sort_field": "modified",
  "sort_order": "DESC"
}
