{
  "doctype": "DocType",
  "name": "AlphaX POS QR Table Token",
  "module": "AlphaX POS Suite",
  "custom": 0,
  "istable": 0,
  "autoname": "format:QRT-{table}-{####}",
  "engine": "InnoDB",
  "fields": [
    {
      "fieldname": "table",
      "label": "Table",
      "fieldtype": "Link",
      "options": "AlphaX POS Table",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "outlet",
      "label": "Outlet",
      "fieldtype": "Link",
      "options": "AlphaX POS Outlet",
      "in_list_view": 1
    },
    {
      "fieldname": "token",
      "label": "Token",
      "fieldtype": "Data",
      "reqd": 1,
      "unique": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "is_active",
      "label": "Active",
      "fieldtype": "Check",
      "default": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "last_used_on",
      "label": "Last Used",
      "fieldtype": "Datetime",
      "read_only": 1
    },
    {
      "fieldname": "expires_on",
      "label": "Expires On",
      "fieldtype": "Datetime",
      "description": "Optional: token rejected after this datetime."
    }
  ],
  "permissions": [
    {"role": "AlphaX POS Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "AlphaX POS Supervisor", "read": 1, "write": 1, "create": 1},
    {"role": "AlphaX POS Cashier", "read": 1},
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1}
  ],
  "sort_field": "modified",
  "sort_order": "DESC"
}
